# ============================================================================
# AZURE COSMOS DB - Chat Conversations
# ============================================================================
COSMOS_ENDPOINT=https://fundomoraga.documents.azure.com:443/
COSMOS_KEY=your_cosmos_key_here
COSMOS_DATABASE=chatbot
COSMOS_CONTAINER=conversations

# ============================================================================
# AZURE COSMOS DB - Prompts (Entrenamiento/Hernando)
# ============================================================================
# Database and container for dynamic prompt loading
COSMOS_PROMPTS_DB=Entrenamiento
COSMOS_PROMPTS_CONTAINER=Hernando
COSMOS_PROMPTS_PERSONA=Hernando

# ============================================================================
# OPENAI API
# ============================================================================
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-5.2-2025-12-11
# Optional: Comma or semicolon-separated list of fallback models
OPENAI_MODEL_FALLBACKS=gpt-5.2,gpt-4o

# ============================================================================
# INSTAGRAM
# ============================================================================
INSTAGRAM_ACCESS_TOKEN=your_token_here
INSTAGRAM_PAGE_ID=your_page_id_here
WEBHOOK_VERIFY_TOKEN=your_secure_webhook_token_here

# ============================================================================
# GOOGLE CALENDAR (Optional)
# ============================================================================
GOOGLE_CALENDAR_ID=your_calendar_id@gmail.com
GOOGLE_SERVICE_ACCOUNT_FILE=/path/to/service-account.json
# Or use the JSON directly (base64 encoded or raw JSON):
# GOOGLE_SERVICE_ACCOUNT_JSON={"type": "service_account", ...}
GOOGLE_CALENDAR_TIMEZONE=America/Santiago

# ============================================================================
# EMAIL / Resend
# ============================================================================
RESEND_API_KEY=re_xxx

# ============================================================================
# PAYMENT VERIFICATION (Gmail IMAP)
# ============================================================================
GMAIL_ACCOUNT=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here
GMAIL_IMAP_LABEL=Label_to_monitor

# ============================================================================
# AZURE TRANSLATOR (Optional)
# ============================================================================
AZURE_TRANSLATOR_ENDPOINT=https://hernando.cognitiveservices.azure.com/
AZURE_TRANSLATOR_KEY=your_key_here
AZURE_TRANSLATOR_REGION=southcentralus

# ============================================================================
# BOT CONFIGURATION
# ============================================================================
BOT_NAME=Fundo Moraga Bot
MAX_CONVERSATION_HISTORY=10
REMINDER_SCHEDULER_ENABLED=false
OPENAI_DISABLE_COOLDOWN_SECONDS=600

# ============================================================================
# DEPLOYMENT (Railway, Render, etc.)
# ============================================================================
PORT=5000
ENVIRONMENT=production
